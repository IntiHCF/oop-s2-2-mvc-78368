@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Inspections This Month</h5>
                <p class="card-text display-6">@ViewBag.MonthlyInspections</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Failed Inspections</h5>
                <p class="card-text display-6">@ViewBag.FailedInspections</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Overdue Follow-Ups</h5>
                <p class="card-text display-6">@ViewBag.OverdueFollowUps</p>
            </div>
        </div>
    </div>
</div>

<h2 class="mb-3">Filter Premises</h2>
<form class="row g-3 mb-4" method="get" asp-controller="Dashboard" asp-action="Index">
    <div class="col-md-4">
        <label for="town" class="form-label">Town</label>
        <input type="text" class="form-control" id="town" name="town" value="@Context.Request.Query["town"]" />
    </div>
    <div class="col-md-4">
        <label for="risk" class="form-label">Risk Rating</label>
        <input type="text" class="form-control" id="risk" name="risk" value="@Context.Request.Query["risk"]" />
    </div>
    <div class="col-md-4 align-self-end">
        <button type="submit" class="btn btn-success w-100">Filter</button>
    </div>
</form>

<h2>Premises List</h2>
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Town</th>
            <th>Risk Rating</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in ViewBag.FilteredPremises)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Town</td>
                <td>@p.RiskRating</td>
            </tr>
        }
    </tbody>
</table>