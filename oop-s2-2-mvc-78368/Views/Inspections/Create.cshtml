@model oop_s2_2_mvc_78368.Models.Inspection

@{
    ViewData["Title"] = "Create Inspection";
}

<h1>Create Inspection</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="PremisesId" class="form-label">Premises</label>
        <select asp-for="PremisesId" class="form-select">
            @foreach (var premise in ViewBag.PremisesList)
            {
                <option value="@premise.Id">@premise.Name (@premise.Town)</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="InspectionDate" class="form-label">Inspection Date</label>
        <input asp-for="InspectionDate" class="form-control" type="date" />
    </div>

    <div class="mb-3">
        <label asp-for="Score" class="form-label">Score</label>
        <input asp-for="Score" class="form-control" type="number" min="0" max="100" />
    </div>

    <div class="mb-3">
        <label asp-for="Outcome" class="form-label">Outcome</label>
        <select asp-for="Outcome" class="form-select">
            <option value="Pass">Pass</option>
            <option value="Fail">Fail</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
</form>