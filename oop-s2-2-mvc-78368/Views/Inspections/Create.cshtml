@model Inspection

<h1>Create Inspection</h1>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="PremisesId" />

    <label>Inspection Date:</label>
    <input asp-for="InspectionDate" type="date" /><br />

    <label>Score:</label>
    <input asp-for="Score" type="number" min="0" max="100" /><br />

    <label>Outcome:</label>
    <select asp-for="Outcome">
        <option value="Pass">Pass</option>
        <option value="Fail">Fail</option>
    </select><br />

    <label>Notes:</label>
    <textarea asp-for="Notes"></textarea><br />

    <button type="submit">Create</button>
</form>