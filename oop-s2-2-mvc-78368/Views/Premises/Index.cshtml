@model IEnumerable<oop_s2_2_mvc_78368.Models.Premises>

<h1 class="mb-4">Premises</h1>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk Rating</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Address</td>
                <td>@p.Town</td>
                <td>@p.RiskRating</td>
            </tr>
        }
    </tbody>
</table>