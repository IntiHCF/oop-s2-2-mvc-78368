@model oop_s2_2_mvc_78368.Models.Premises
@{
    ViewData["Title"] = "Edit Premises";
}

<h1>Edit Premises</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Town" class="form-label"></label>
        <input asp-for="Town" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="RiskRating" class="form-label"></label>
        <select asp-for="RiskRating" class="form-select">
            <option>Low</option>
            <option>Medium</option>
            <option>High</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Save Changes</button>
</form>