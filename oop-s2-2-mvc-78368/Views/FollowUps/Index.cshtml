@model IEnumerable<oop_s2_2_mvc_78368.Models.FollowUp>

<h1 class="mb-4">Follow-Ups</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
{
    <a class="btn btn-primary mb-3" asp-action="Create">Create New Follow-Up</a>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Inspection</th>
            <th>Premises</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Closed Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@f.Inspection?.Id</td>
                <td>@f.Inspection?.Premises?.Name</td>
                <td>@f.DueDate.ToShortDateString()</td>
                <td>@f.Status</td>
                <td>@f.ClosedDate?.ToShortDateString()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@f.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@f.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@f.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>